@model CrudAlumnos.Models.Alumno

@{
    ViewData["Title"] = "Editar Alumno";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <div class="card shadow-sm">
            <div class="card-header bg-warning text-dark">
                <h5 class="mb-0"><i class="bi bi-pencil-square me-2"></i>Editar Alumno</h5>
            </div>
            <div class="card-body">
                <form asp-action="Edit">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger"></div>
                    <input type="hidden" asp-for="CodAlumno" />

                    <div class="mb-3">
                        <label asp-for="Nombre" class="form-label"></label>
                        <input asp-for="Nombre" class="form-control" />
                        <span asp-validation-for="Nombre" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Apellido" class="form-label"></label>
                        <input asp-for="Apellido" class="form-control" />
                        <span asp-validation-for="Apellido" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Edad" class="form-label"></label>
                        <input asp-for="Edad" class="form-control" type="number" min="1" max="120" />
                        <span asp-validation-for="Edad" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="Sexo" class="form-label"></label>
                        <select asp-for="Sexo" class="form-select">
                            <option value="">-- Seleccione --</option>
                            <option value="M" @(Model.Sexo == "M" ? "selected" : "")>Masculino</option>
                            <option value="F" @(Model.Sexo == "F" ? "selected" : "")>Femenino</option>
                        </select>
                        <span asp-validation-for="Sexo" class="text-danger small"></span>
                    </div>

                    <div class="mb-3">
                        <label asp-for="CodCiudad" class="form-label"></label>
                        <select asp-for="CodCiudad" asp-items="ViewBag.CodCiudad" class="form-select">
                            <option value="">-- Seleccione ciudad --</option>
                        </select>
                        <span asp-validation-for="CodCiudad" class="text-danger small"></span>
                    </div>

                    <div class="d-flex justify-content-between">
                        <a asp-action="Index" class="btn btn-secondary">
                            <i class="bi bi-arrow-left me-1"></i>Volver
                        </a>
                        <button type="submit" class="btn btn-warning">
                            <i class="bi bi-save me-1"></i>Actualizar
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
